{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Browser Switcher",
  "version": "0.1.5",
  "identifier": "dev.local.browser-switcher",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "About Browser Switcher",
        "width": 440,
        "height": 300,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": "all"
  }
}
